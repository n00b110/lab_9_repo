<edit_description>
Create environment configuration template
</edit_description>

```
# ===== Model Configuration =====
MODEL_NAME=microsoft/phi-2
MODEL_PATH=./models
ENVIRONMENT=production

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_TIMEOUT=30

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_DIR=./logs
DEBUG_MODE=False

# ===== Model Generation Configuration =====
MAX_RESPONSE_LENGTH=500
MIN_RESPONSE_LENGTH=50
TEMPERATURE=0.7
TOP_P=0.95
BATCH_SIZE=1

# ===== Evaluation Configuration =====
EVAL_BATCH_SIZE=1

# ===== Performance Configuration =====
ENABLE_CACHING=True
CACHE_SIZE=100

# ===== Monitoring Configuration =====
TRACK_METRICS=True

# ===== Streamlit Configuration =====
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
```

<file_path>
lab_9_repo/Makefile
</file_path>

<edit_description>
Create Makefile for development convenience commands
</edit_description>

```
.PHONY: help install clean run api frontend test logs evaluate docker-build docker-run docker-stop format lint train env

help:
	@echo "Domain Adapted AI Assistant - Development Commands"
	@echo "===================================================="
	@echo "Setup Commands:"
	@echo "  make install       - Install dependencies"
	@echo "  make env           - Create .env file from template"
	@echo "  make clean         - Clean up cache and logs"
	@echo ""
	@echo "Development Commands:"
	@echo "  make api           - Start API server (port 8000)"
	@echo "  make frontend      - Start Streamlit frontend (port 8501)"
	@echo "  make run           - Run both API and frontend"
	@echo "  make train         - Train/fine-tune the model"
	@echo ""
	@echo "Testing & Evaluation:"
	@echo "  make test          - Run evaluation suite"
	@echo "  make logs          - View application logs"
	@echo ""
	@echo "Code Quality:"
	@echo "  make format        - Format code with black"
	@echo "  make lint          - Run linting checks"
	@echo ""
	@echo "Docker Commands:"
	@echo "  make docker-build  - Build Docker image"
	@echo "  make docker-run    - Run with docker-compose"
	@echo "  make docker-stop   - Stop Docker containers"

install:
	python -m venv venv
	. venv/bin/activate && pip install --upgrade pip && pip install -r requirements.txt
	@echo "✅ Installation complete! Run 'source venv/bin/activate' to activate the virtual environment"

env:
	cp .env.example .env
	@echo "✅ Created .env file from template. Please update with your settings."

clean:
	rm -rf __pycache__ .pytest_cache .coverage
	find . -type d -name __pycache__ -exec rm -rf {} +
	find . -type f -name "*.pyc" -delete
	rm -f logs/*.log
	@echo "✅ Cleaned up cache and logs"

api:
	python -m uvicorn app.api:app --reload --host 0.0.0.0 --port 8000 --log-level info

frontend:
	streamlit run app/streamlit_app.py --server.port 8501 --server.address 0.0.0.0

run:
	@echo "Starting API and Frontend..."
	@echo "API will run on: http://localhost:8000"
	@echo "Frontend will run on: http://localhost:8501"
	@echo "Press Ctrl+C to stop"
	python -m uvicorn app.api:app --reload --host 0.0.0.0 --port 8000 & \
	streamlit run app/streamlit_app.py --server.port 8501 --server.address 0.0.0.0

train:
	python training/train_lora.py

test:
	python evaluation/evaluate.py

logs:
	tail -f logs/app.log

docker-build:
	docker build -t domain-ai-assistant:latest .
	@echo "✅ Docker image built successfully"

docker-run:
	docker-compose up -d
	@echo "✅ Docker containers started"
	@echo "API running on http://localhost:8000"
	@echo "Frontend running on http://localhost:8501"

docker-stop:
	docker-compose down
	@echo "✅ Docker containers stopped"

format:
	black app/ training/ evaluation/ monitoring/
	@echo "✅ Code formatted with black"

lint:
	python -m flake8 app/ training/ evaluation/ monitoring/ --max-line-length=100 --ignore=E203,W503
	@echo "✅ Linting complete"

.DEFAULT_GOAL := help
```

<file_path>
lab_9_repo/Dockerfile.streamlit
</file_path>

<edit_description>
Create Dockerfile specifically for Streamlit application
</edit_description>

```
FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application
COPY . .

# Create logs directory
RUN mkdir -p logs

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0 \
    STREAMLIT_SERVER_HEADLESS=true

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "app/streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0"]
```

